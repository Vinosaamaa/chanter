# Chanter local development environment

# Infrastructure (Docker Compose)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=chanter
POSTGRES_PASSWORD=chanter
POSTGRES_DB=chanter

REDIS_HOST=localhost
REDIS_PORT=6379

KAFKA_BOOTSTRAP_SERVERS=localhost:19092

MINIO_ENDPOINT=http://localhost:9000
MINIO_ROOT_USER=chanter
MINIO_ROOT_PASSWORD=chantersecret

# Backend services (run on host during development)
GATEWAY_PORT=8080
AUTH_PORT=8081
AUTH_SERVICE_URL=http://localhost:8081
COMMUNITY_PORT=8082
COMMUNITY_SERVICE_URL=http://localhost:8082
MESSAGE_PORT=8083
MESSAGE_SERVICE_URL=http://localhost:8083
MEDIA_PORT=8084
MEDIA_SERVICE_URL=http://localhost:8084
AGENT_PORT=8085
AGENT_SERVICE_URL=http://localhost:8085

# JWT (required — set in your local .env for auth-service and gateway)
# Local-only example (32+ chars). Generate a new secret for shared environments.
CHANTER_JWT_SECRET=chanter-local-dev-jwt-secret-32bytes!!

# Frontend
VITE_API_BASE_URL=http://localhost:8080
