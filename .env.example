# Chanter local development environment

# Infrastructure (Docker Compose)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=chanter
POSTGRES_PASSWORD=chanter
POSTGRES_DB=chanter

REDIS_HOST=localhost
REDIS_PORT=6379

KAFKA_BOOTSTRAP_SERVERS=localhost:19092

MINIO_ENDPOINT=http://localhost:9000
MINIO_ROOT_USER=chanter
MINIO_ROOT_PASSWORD=chantersecret

# Backend services (run on host during development)
GATEWAY_PORT=8080
AUTH_PORT=8081
AUTH_SERVICE_URL=http://localhost:8081
COMMUNITY_PORT=8082
COMMUNITY_SERVICE_URL=http://localhost:8082
MESSAGE_PORT=8083
MESSAGE_SERVICE_URL=http://localhost:8083
MEDIA_PORT=8084
MEDIA_SERVICE_URL=http://localhost:8084
AGENT_PORT=8085
AGENT_SERVICE_URL=http://localhost:8085
ANALYTICS_PORT=8086
ANALYTICS_SERVICE_URL=http://localhost:8086
SEARCH_PORT=8088
SEARCH_SERVICE_URL=http://localhost:8088
NOTIFICATION_PORT=8089
NOTIFICATION_SERVICE_URL=http://localhost:8089
REALTIME_PORT=8087
REALTIME_SERVICE_URL=ws://localhost:8087

# LiveKit local media plane (Workable Product — wired in #61)
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_HTTP_URL=http://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# Product stack (make product-up)
FRONTEND_PORT=5173

# Demo personas (scripts/seed-workable-product-demo.sh) — set in your local .env
# DEMO_PASSWORD=your-local-demo-password

# JWT (required — set via `make product-env` or paste your own 32+ char secret)
# Do NOT commit real secrets. Empty placeholders only in this example (SEC-04).
CHANTER_JWT_SECRET=

# Shared credential for backend-only service calls. Separate random value from JWT.
CHANTER_INTERNAL_SERVICE_TOKEN=

# Frontend (optional — leave empty in dev to use the Vite /api proxy)
# VITE_API_BASE=http://localhost:8080

# Staging public URL (#101) — set on the staging host only (HTTPS origin, no trailing slash)
# CHANTER_PUBLIC_BASE_URL=https://staging.chanter.example
# LIVEKIT_URL=wss://staging.chanter.example/livekit

# Production auth (#102)
# CHANTER_AUTH_REQUIRE_EMAIL_VERIFICATION=true
# CHANTER_EMAIL_PROVIDER=log
# CHANTER_EMAIL_FROM=noreply@chanter.example
# Google SSO (optional — button appears on /sign-in when both are set)
# CHANTER_OAUTH_GOOGLE_CLIENT_ID=
# CHANTER_OAUTH_GOOGLE_CLIENT_SECRET=
# OAuth redirect URI to register with Google: ${CHANTER_PUBLIC_BASE_URL}/oauth/callback/google
# Auth rate limit (per IP+action window)
# CHANTER_AUTH_RATE_LIMIT_MAX=30
# CHANTER_AUTH_RATE_LIMIT_WINDOW=1m

# LLM providers (#97) — disabled by default; Ask AI uses RAG/keyword without an LLM
# CHANTER_LLM_ENABLED=false
# CHANTER_LLM_PROVIDER=ollama
# CHANTER_LLM_MODEL=llama3.2
# OLLAMA_BASE_URL=http://localhost:11434
# For OpenAI-compatible APIs:
# CHANTER_LLM_PROVIDER=openai
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=
# Embedding provider (#95) optional Ollama:
# CHANTER_EMBEDDINGS_PROVIDER=hashing
# CHANTER_EMBEDDINGS_PROVIDER=ollama
# OLLAMA_EMBED_MODEL=nomic-embed-text
