#!/bin/sh
# Block direct pushes to main. All changes must land via pull request.

protected_branch='main'

while read -r local_ref local_sha remote_ref remote_sha; do
  if [ -z "$remote_ref" ]; then
    continue
  fi

  branch="${remote_ref#refs/heads/}"

  if [ "$branch" = "$protected_branch" ]; then
    echo "ERROR: Direct push to '${protected_branch}' is not allowed." >&2
    echo "Create a feature branch, open a pull request, and merge after approval." >&2
    exit 1
  fi
done

exit 0
